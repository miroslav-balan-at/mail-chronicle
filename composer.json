{
    "name": "miroslav-balan/mail-chronicle",
    "description": "WordPress plugin for email logging with multi-provider support (Mailgun, SendGrid, etc.)",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Miroslav Balan",
            "email": "miroslav@balan.at"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "mockery/mockery": "^1.5",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "MailChronicle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MailChronicle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:coverage": "phpunit --coverage-html coverage",
        "test:coverage-text": "phpunit --coverage-text",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "phpstan": "phpstan analyse --configuration=phpstan.neon"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
